<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:LedCube.Core.UI.Dialog.SelectAnimationDialog"
        xmlns:playlistControl="clr-namespace:LedCube.Core.UI.Controls.PlaylistControl;assembly=LedCube.Core.UI"
        x:Class="LedCube.Core.UI.Dialog.SelectAnimationDialog.SelectAnimationDialog"
        x:DataType="local:SelectAnimationDialogViewModel"
        x:Name="DialogWindow"
        Height="400" Width="350"
        Title="Select Animation"
        CanResize="False">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="5,0,0,0" Padding="8" MinWidth="50"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"/>
            <Button Margin="5,0,0,0" Padding="8" MinWidth="50"
                    Content="Add"
                    Command="{Binding AddCommand}"
                    CommandParameter="{Binding #DialogWindow}"
                    IsDefault="True"/>
        </StackPanel>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,2">
                <TextBlock FontSize="9" Foreground="DimGray" Text="Filter:"/>
                <TextBox Text="{Binding SearchText}"/>
            </StackPanel>

            <ListBox Grid.Row="1"
                     ItemsSource="{Binding FilteredAnimations}"
                     SelectedItem="{Binding SelectedAnimation, Mode=TwoWay}"
                     Margin="0,2"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="BorderBrush" Value="DimGray"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate DataType="{x:Type playlistControl:AnimationViewModel}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" FontSize="10" Foreground="DimGray" Text="Name:"/>
                            <TextBlock Grid.Row="1" Grid.Column="0" FontSize="10" Foreground="DimGray" Text="Description:"/>
                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="10" Text="{Binding Name}"/>
                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="10" Text="{Binding Description}"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Margin="0,2">
                <TextBlock FontSize="9" Foreground="DimGray" Text="Name:"/>
                <TextBox Text="{Binding AnimationInstanceName}"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="clr-namespace:LedCube.Core.UI.Helpers"
             xmlns:vm="clr-namespace:LedCube.Core.UI.Controls.SettingsDialog"
             x:Class="LedCube.Core.UI.Controls.SettingsDialog.SettingsPage_StreamerSettings"
             x:DataType="vm:CubeStreamerSettingsViewModel">
    <StackPanel>
        <TextBlock FontSize="16" FontWeight="SemiBold" Text="Streaming" Margin="0,0,0,8"/>
        <HeaderedContentControl Header="Connection" Margin="0,0,0,8">
            <Grid Margin="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Hostname"/>
                <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Hostname}"/>
                <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Port" Margin="0,8,0,0"/>
                <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0" Text="{Binding Port}"/>
            </Grid>
        </HeaderedContentControl>
        <HeaderedContentControl Header="Discovery" Margin="0,0,0,8">
            <StackPanel Margin="8">
                <CheckBox Content="Search per broadcast" IsChecked="{Binding SearchPerBroadcast}"/>
            </StackPanel>
        </HeaderedContentControl>
        <HeaderedContentControl Header="Cube orientation" Margin="0,0,0,8">
            <StackPanel Margin="8" Spacing="6">
                <TextBlock Text="Maps the canonical animation space onto your physical cube. Applied to the streamed (UDP) output and to the preview's 'Show as installed' mode; animations stay authored in canonical space."
                           TextWrapping="Wrap" FontSize="11" Foreground="#A0A0A0"/>
                <Grid ColumnDefinitions="180,*" RowDefinitions="Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Hardware front (wiring)"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              ItemsSource="{x:Static helpers:EnumValues.Orientation3Ds}"
                              SelectedItem="{Binding Projection.HardwareFront}"/>
                    <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Handedness" Margin="0,6,0,0"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,6,0,0"
                              ItemsSource="{x:Static helpers:EnumValues.CartesianOrientations}"
                              SelectedItem="{Binding Projection.Orientation}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Installed front" Margin="0,6,0,0"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" Margin="0,6,0,0"
                              ItemsSource="{x:Static helpers:EnumValues.Orientation3Ds}"
                              SelectedItem="{Binding Projection.InstallationFront}"/>
                </Grid>
            </StackPanel>
        </HeaderedContentControl>
        <HeaderedContentControl Header="Diagnostics" Margin="0,0,0,8">
            <StackPanel Margin="8">
                <CheckBox Content="Enable trace datagram logging"
                          IsChecked="{Binding EnableTraceDatagramLogging}"/>
                <TextBlock Text="⚠ Logs every sent/received datagram (incl. raw bytes) at Trace level. Runs on the per-frame hot path — impacts streaming performance. Enable only for debugging."
                           Foreground="#E0A030" TextWrapping="Wrap" FontSize="11" Margin="24,2,0,0"/>
            </StackPanel>
        </HeaderedContentControl>
    </StackPanel>
</UserControl>

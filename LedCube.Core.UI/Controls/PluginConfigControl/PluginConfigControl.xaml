<UserControl x:Class="LedCube.Core.UI.Controls.PluginConfigControl.PluginConfigControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:LedCube.Core.UI.Controls.PluginConfigControl"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="300"
             d:DataContext="{d:DesignInstance local:PluginConfigControlViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="EntryLabel" TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>
        <Style x:Key="EntryRow" TargetType="Grid">
            <Setter Property="Margin" Value="0,3,0,3"/>
        </Style>

        <!-- Bool template -->
        <DataTemplate x:Key="BoolEntryTemplate">
            <Grid Style="{StaticResource EntryRow}"
                  ToolTip="{Binding Descriptor.Description}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Descriptor.DisplayName}"
                           Style="{StaticResource EntryLabel}"/>
                <CheckBox Grid.Column="1"
                          IsChecked="{Binding BoolValue}"
                          VerticalAlignment="Center"/>
            </Grid>
        </DataTemplate>

        <!-- Int template -->
        <DataTemplate x:Key="IntEntryTemplate">
            <Grid Style="{StaticResource EntryRow}"
                  ToolTip="{Binding Descriptor.Description}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Descriptor.DisplayName}"
                           Style="{StaticResource EntryLabel}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding StringValue, UpdateSourceTrigger=LostFocus}"/>
            </Grid>
        </DataTemplate>

        <!-- Float template -->
        <DataTemplate x:Key="FloatEntryTemplate">
            <Grid Style="{StaticResource EntryRow}"
                  ToolTip="{Binding Descriptor.Description}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Descriptor.DisplayName}"
                           Style="{StaticResource EntryLabel}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding StringValue, UpdateSourceTrigger=LostFocus}"/>
            </Grid>
        </DataTemplate>

        <!-- String template -->
        <DataTemplate x:Key="StringEntryTemplate">
            <Grid Style="{StaticResource EntryRow}"
                  ToolTip="{Binding Descriptor.Description}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Descriptor.DisplayName}"
                           Style="{StaticResource EntryLabel}"/>
                <TextBox Grid.Column="1"
                         Text="{Binding StringValue, UpdateSourceTrigger=LostFocus}"/>
            </Grid>
        </DataTemplate>

        <!-- Enum template -->
        <DataTemplate x:Key="EnumEntryTemplate">
            <Grid Style="{StaticResource EntryRow}"
                  ToolTip="{Binding Descriptor.Description}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Descriptor.DisplayName}"
                           Style="{StaticResource EntryLabel}"/>
                <ComboBox Grid.Column="1"
                          ItemsSource="{Binding Descriptor.EnumValues}"
                          SelectedItem="{Binding EnumValue}"/>
            </Grid>
        </DataTemplate>

        <local:ConfigEntryTemplateSelector x:Key="EntrySelector"
            BoolTemplate="{StaticResource BoolEntryTemplate}"
            IntTemplate="{StaticResource IntEntryTemplate}"
            FloatTemplate="{StaticResource FloatEntryTemplate}"
            StringTemplate="{StaticResource StringEntryTemplate}"
            EnumTemplate="{StaticResource EnumEntryTemplate}"/>
    </UserControl.Resources>

    <Grid>
        <!-- No selection placeholder -->
        <TextBlock Foreground="Gray"
                   Text="No animation selected."
                   VerticalAlignment="Center"
                   HorizontalAlignment="Center">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding HasSelection}" Value="False">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel Margin="4">
                <!-- General settings -->
                <GroupBox Header="General" Margin="0,0,0,4" Padding="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Grid.Column="0"
                                   Text="Repeat (0=&#x221E;)"
                                   Style="{StaticResource EntryLabel}"
                                   Margin="0,3,8,3"/>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 Margin="0,3,0,3"
                                 Text="{Binding RepeatCount, UpdateSourceTrigger=LostFocus}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0"
                                   Text="Frame Time (ms)"
                                   Style="{StaticResource EntryLabel}"
                                   Margin="0,3,8,3"
                                   ToolTip="Override the animation's default frame time. Leave empty to use plugin default."/>
                        <TextBox Grid.Row="1" Grid.Column="1"
                                 Margin="0,3,0,3"
                                 Text="{Binding FrameTimeOverrideMs, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>
                </GroupBox>

                <!-- Animation-specific settings -->
                <GroupBox Header="Animation Settings"
                          Padding="4"
                          Visibility="{Binding HasConfigDescriptors, Converter={StaticResource BoolToVis}}">
                    <ItemsControl ItemsSource="{Binding ConfigEntries}"
                                  ItemTemplateSelector="{StaticResource EntrySelector}"/>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>

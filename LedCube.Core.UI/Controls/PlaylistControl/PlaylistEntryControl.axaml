<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:LedCube.Core.UI.Controls.PlaylistControl"
             xmlns:converters="clr-namespace:LedCube.Core.UI.Converters"
             xmlns:avconv="clr-namespace:Avalonia.Data.Converters;assembly=Avalonia.Base"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="LedCube.Core.UI.Controls.PlaylistControl.PlaylistEntryControl"
             x:DataType="local:PlaylistEntryControlViewModel">
    <UserControl.Resources>
        <converters:VisibleWhenIntConverter x:Key="VisWhenInt"/>
    </UserControl.Resources>

    <Grid ColumnDefinitions="14,Auto,*,Auto">
        <!-- State indicator: Active=1 dot, Playing=2 play icon, Paused=3 pause icon -->
        <Panel Grid.Column="0" VerticalAlignment="Center">
            <Ellipse Width="6" Height="6" Fill="CornflowerBlue"
                     IsVisible="{Binding DisplayState, Converter={StaticResource VisWhenInt}, ConverterParameter=1}"/>
            <materialIcons:MaterialIcon Kind="Play" Width="12" Height="12" Foreground="CornflowerBlue"
                     IsVisible="{Binding DisplayState, Converter={StaticResource VisWhenInt}, ConverterParameter=2}"/>
            <materialIcons:MaterialIcon Kind="Pause" Width="12" Height="12" Classes="muted"
                     IsVisible="{Binding DisplayState, Converter={StaticResource VisWhenInt}, ConverterParameter=3}"/>
        </Panel>

        <!-- Thumbnail (falls back to the type icon until a thumbnail is available) -->
        <Border Grid.Column="1" Width="40" Height="40" Margin="0,0,8,0"
                CornerRadius="4" VerticalAlignment="Center"
                Background="{DynamicResource ControlFillColorDefaultBrush}">
            <Panel>
                <materialIcons:MaterialIcon Width="22" Height="22" Classes="muted"
                                            Kind="{Binding TypeIcon}"
                                            IsVisible="{Binding Thumbnail, Converter={x:Static avconv:ObjectConverters.IsNull}}"/>
                <Image Source="{Binding Thumbnail}" Stretch="UniformToFill"
                       IsVisible="{Binding Thumbnail, Converter={x:Static avconv:ObjectConverters.IsNotNull}}"/>
            </Panel>
        </Border>

        <!-- Instance name over animation name / description, then frame stats -->
        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1">
            <TextBlock Text="{Binding InstanceName}"
                       FontSize="13" FontWeight="SemiBold"
                       TextTrimming="CharacterEllipsis"/>
            <TextBlock Text="{Binding Name}"
                       Classes="muted" FontSize="11"
                       TextTrimming="CharacterEllipsis"
                       IsVisible="{Binding ShowSecondaryName}"/>
            <TextBlock Text="{Binding Description}"
                       Classes="muted" FontSize="11"
                       MaxLines="2" TextWrapping="Wrap" TextTrimming="CharacterEllipsis"/>
            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,1,0,0"
                        IsVisible="{Binding HasTiming}">
                <StackPanel Orientation="Horizontal" IsVisible="{Binding HasFrameCount}">
                    <TextBlock Text="Frames: " Classes="muted" FontSize="10"/>
                    <TextBlock Text="{Binding FrameCount}" Classes="muted" FontSize="10"/>
                </StackPanel>
                <TextBlock Text="{Binding FpsText}" Classes="muted" FontSize="10"
                           IsVisible="{Binding HasFps}"/>
                <StackPanel Orientation="Horizontal" IsVisible="{Binding HasFrameCount}">
                    <materialIcons:MaterialIcon Kind="ClockOutline" Width="11" Height="11"
                                                Classes="muted" VerticalAlignment="Center" Margin="0,0,2,0"/>
                    <TextBlock Text="{Binding DurationText}" Classes="muted" FontSize="10"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>

        <!-- Right: index + type icon -->
        <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="8,0,0,0" Spacing="2"
                    HorizontalAlignment="Right">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <TextBlock Text="#" Classes="muted" FontSize="10"/>
                <TextBlock Text="{Binding Index}" Classes="muted" FontSize="10"/>
            </StackPanel>
            <materialIcons:MaterialIcon Kind="{Binding TypeIcon}" Classes="muted"
                                        Width="14" Height="14" HorizontalAlignment="Right"/>
        </StackPanel>
    </Grid>
</UserControl>

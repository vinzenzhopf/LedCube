<UserControl x:Class="LedCube.Core.UI.Controls.PlaylistControl.PlaylistEntryControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:LedCube.Core.UI.Controls.PlaylistControl"
             mc:Ignorable="d"
             d:DesignWidth="400"
             d:DataContext="{d:DesignInstance local:PlaylistEntryControlViewModel, IsDesignTimeCreatable=True}">
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- State indicator column (dot / play / pause) -->
            <Grid Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" VerticalAlignment="Center">
                <!-- Active (loaded, stopped) — filled dot -->
                <Ellipse Width="6" Height="6"
                         Fill="{DynamicResource MahApps.Brushes.Accent}">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DisplayState}"
                                             Value="{x:Static local:EntryDisplayState.Active}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <!-- Playing — play icon -->
                <iconPacks:PackIconModern Kind="ControlPlay" Width="12" Height="12"
                                          Foreground="{DynamicResource MahApps.Brushes.Accent}">
                    <iconPacks:PackIconModern.Style>
                        <Style TargetType="iconPacks:PackIconModern">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DisplayState}"
                                             Value="{x:Static local:EntryDisplayState.Playing}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </iconPacks:PackIconModern.Style>
                </iconPacks:PackIconModern>
                <!-- Paused — pause icon -->
                <iconPacks:PackIconModern Kind="ControlPause" Width="12" Height="12"
                                          Foreground="{DynamicResource MahApps.Brushes.Gray2}">
                    <iconPacks:PackIconModern.Style>
                        <Style TargetType="iconPacks:PackIconModern">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DisplayState}"
                                             Value="{x:Static local:EntryDisplayState.Paused}">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </iconPacks:PackIconModern.Style>
                </iconPacks:PackIconModern>
            </Grid>

            <!-- Instance name — accent colour when active/playing/paused -->
            <TextBlock Grid.Column="1" Grid.Row="0" Grid.ColumnSpan="2"
                       Text="{Binding InstanceName}"
                       FontWeight="Bold">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding DisplayState}"
                                         Value="{x:Static local:EntryDisplayState.Active}">
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayState}"
                                         Value="{x:Static local:EntryDisplayState.Playing}">
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding DisplayState}"
                                         Value="{x:Static local:EntryDisplayState.Paused}">
                                <Setter Property="Foreground" Value="{DynamicResource MahApps.Brushes.Accent}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <WrapPanel Grid.Column="3" Grid.Row="0" HorizontalAlignment="Right">
                <TextBlock Text="#" Foreground="Gray"/>
                <TextBlock Text="{Binding Index}" Foreground="Gray"/>
            </WrapPanel>
            <TextBlock Grid.Column="1" Grid.Row="1" Text="{Binding Animation.Name}"/>
            <TextBlock Grid.Column="2" Grid.Row="1" Grid.ColumnSpan="2"
                       Text="{Binding Animation.Description}"/>
        </Grid>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <WrapPanel Grid.Column="0">
                <TextBlock Text="Frames: " Foreground="Gray"/>
                <TextBlock Text="{Binding FrameCount}" Foreground="Gray"/>
            </WrapPanel>
            <WrapPanel Grid.Column="1" HorizontalAlignment="Center">
                <TextBlock Text="FPS: " Foreground="Gray"/>
                <TextBlock Text="{Binding FrameFrequency}" Foreground="Gray"/>
            </WrapPanel>
            <WrapPanel Grid.Column="2" HorizontalAlignment="Right">
                <iconPacks:PackIconMaterialDesign
                    Kind="AccessTime"
                    Foreground="Gray"
                    Height="12" Width="12"
                    VerticalAlignment="Center"
                    Margin="0,0,2,0"/>
                <TextBlock Text="{Binding AnimationLength}" Foreground="Gray"/>
            </WrapPanel>
        </Grid>
    </StackPanel>
</UserControl>

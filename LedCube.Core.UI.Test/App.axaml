<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sty="using:FluentAvalonia.Styling"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="LedCube.Core.UI.Test.App"
             RequestedThemeVariant="Default">
    <!-- Mirrors LedCube.Streamer.UI/App.axaml so controls find the same styles/resources under test. -->
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://LedCube.Core.UI/Styles/General.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>
    <Application.Styles>
        <sty:FluentAvaloniaTheme />
        <StyleInclude Source="avares://LedCube.Core.UI/Styles/Controls.axaml" />
        <StyleInclude Source="avares://LedCube.Core.UI/Styles/Components.axaml" />
        <materialIcons:MaterialIconStyles />
    </Application.Styles>
</Application>

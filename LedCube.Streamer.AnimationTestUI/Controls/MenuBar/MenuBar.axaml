<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:local="clr-namespace:LedCube.Streamer.AnimationTestUI.Controls.MenuBar"
             x:Class="LedCube.Streamer.AnimationTestUI.Controls.MenuBar.MenuBar"
             x:DataType="local:MenuBarViewModel">
    <Menu>
        <MenuItem Header="_File">
            <MenuItem Header="_Settings" Command="{Binding OpenSettingsCommand}">
                <MenuItem.Icon>
                    <materialIcons:MaterialIcon Kind="Wrench" Width="16" Height="16"/>
                </MenuItem.Icon>
            </MenuItem>
            <Separator/>
            <MenuItem Header="E_xit" Command="{Binding ExitApplicationCommand}"/>
        </MenuItem>
        <MenuItem Header="_Tools">
            <MenuItem Header="Show Debug _Log" ToggleType="CheckBox"/>
        </MenuItem>
    </Menu>
</UserControl>
